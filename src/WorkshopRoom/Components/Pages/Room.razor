@page "/"
@rendermode InteractiveServer
@implements IDisposable
@inject SessionStoreReader Reader
@inject RoomConfig Config
@inject WorkshopArchive Archive
@inject DeskAgentStore DeskAgents
@inject IJSRuntime JS

<PageTitle>the workshop</PageTitle>

<div class="room-head">
    <h1 title="the cairn — the workshop's mark: a stack of trail stones, built one at a time. every desk reads CAIRN.md first."><span class="mark" aria-hidden="true"><svg viewBox="0 0 32 32" fill="currentColor"><ellipse cx="16" cy="25" rx="10" ry="3.4" /><ellipse cx="16.8" cy="17.2" rx="7.2" ry="3.1" /><ellipse cx="15.3" cy="9.8" rx="4.6" ry="2.7" /></svg></span> the workshop</h1>
    <span class="artifact">@if (!string.IsNullOrEmpty(_artifact.Ref)) { <text>on <strong>@_artifact.Ref</strong> &middot; </text> }@_artifact.Title</span>
    <span class="updated">updated @Ago(_now.AddSeconds(-1))</span>
    <div class="view-switch" role="group" aria-label="view detail">
        <button class="seg @(_advanced ? "" : "on")" @onclick="() => _advanced = false" title="just your desks, grouped by workshop, with tokens and signals">simple</button>
        <button class="seg @(_advanced ? "on" : "")" @onclick="() => _advanced = true" title="everything: pulse, metrics, AIC, bench and handoffs">everything</button>
    </div>
    <button class="theme-toggle" @onclick="ToggleTheme" aria-label="@(_isLight ? "switch to dark mode" : "switch to light mode")" title="@(_isLight ? "switch to dark mode" : "switch to light mode")">@(_isLight ? "\u263D dark" : "\u2600 light")</button>
</div>

@if (_advanced)
{
<section class="pulse @PulseClass()">
    <div class="pulse-head">
        <span class="pulse-title">daily pulse <span class="muted">@DateTime.Now.ToString("yyyy-MM-dd")</span></span>
        <span class="verdict v-@PulseClass()">@Arrow() @_pulse.Temperature</span>
    </div>
    <div class="line-viz">
        <div class="line-rule"></div>
        <span class="lbl-above">above the line</span>
        <span class="lbl-below">below the line</span>
        <div class="chips">
            @foreach (var ch in _pulse.Checks)
            {
                <span class="chip c-@ch.Verdict">
                    <span class="chip-name">@ch.Name</span>
                    <span class="chip-detail">@ch.Detail</span>
                </span>
            }
        </div>
    </div>
    <div class="pulse-read">@_pulse.Headline</div>
</section>
}

@if (_advanced)
{
<div class="strip">
    <span class="pill">
        <span class="pill-k">hands-up</span>
        <span class="pill-v">@_health.HandsUpOpen open</span>
    </span>
    <span class="pill @(_health.SendBacks > 0 ? "good" : "warn")">
        <span class="pill-k">send-back</span>
        <span class="pill-v">@_health.SendBacks / @_health.Reviews reviews</span>
        <span class="pill-note">@(_health.SendBacks > 0 ? "gate is live" : "gate not gating")</span>
    </span>
    <span class="pill">
        <span class="pill-k">shipped</span>
        <span class="pill-v">@_health.Shipped / @_health.Handoffs handoffs</span>
    </span>
    <span class="pill">
        <span class="pill-k">confidence</span>
        <span class="pill-v">@Conf(_health.ConfMin)&ndash;@Conf(_health.ConfMax)</span>
        <span class="pill-note">spread @Spread()</span>
    </span>
    <span class="pill">
        <span class="pill-k">workshop spend</span>
        <span class="pill-v">@FmtTok(_desks.Sum(d => d.TokensIn + d.TokensOut))</span>
        <span class="pill-note">output tokens, live</span>
    </span>
    <span class="pill">
        <span class="pill-k">workshop AIC</span>
        <span class="pill-v">@_desks.Sum(d => d.Aic).ToString("N0")</span>
        <span class="pill-note">credits, last sync</span>
    </span>
</div>
}

<div class="setup-bar @(_setupOpen ? "open" : "collapsed")" role="button" tabindex="0" aria-expanded="@(_setupOpen ? "true" : "false")" aria-controls="setup-body"
     @onclick="ToggleSetup" @onkeydown="SetupKey" title="@(_setupOpen ? "hide this section" : "create a workshop or open a desk")">
    <span class="setup-caret" aria-hidden="true">@(_setupOpen ? "\u25BE" : "\u25B8")</span>
    @if (_setupOpen)
    {
        <span class="muted">first set up a workshop (a repo), then open desks in it &middot; live from session-state, refreshes every 3s</span>
        <span class="setup-hide">hide</span>
    }
    else
    {
        <span class="setup-bar-label">new workshop or desk</span>
        <span class="muted setup-bar-sub">create a workshop, or open a desk in one you already have</span>
    }
</div>

@if (_setupOpen)
{
<div class="setup" id="setup-body">
    <div class="step">
        <span class="step-num">1</span>
        <span class="nd-label">create a workshop:</span>
        <input class="nd-input" @bind="_newWorkshopName" @bind:event="oninput" @onfocus="() => _typing = true" @onblur="() => _typing = false" placeholder="new repo name" aria-label="new workshop repo name" />
        <select class="nd-input" @bind="_workshopOwner" @onfocus="() => _typing = true" @onblur="() => _typing = false" aria-label="workshop owner account">
            @foreach (var l in _ghLogins) { <option value="@l.Login">@l.Login@(l.IsActive ? " (active)" : "")</option> }
        </select>
        <button class="btn" @onclick="StartWorkshop" disabled="@_busy">@(_busy ? "creating..." : "create workshop")</button>
    </div>
    <div class="step sub">
        <span class="nd-label muted">or, no repo needed:</span>
        <input class="nd-input" @bind="_newMiniName" @bind:event="oninput" @onfocus="() => _typing = true" @onblur="() => _typing = false" placeholder="mini-workshop name" aria-label="mini-workshop name" />
        <button class="btn ghost" @onclick="StartMiniWorkshop" disabled="@_busy">create mini-workshop (local)</button>
        <span class="nd-hint">a local folder you point an agent at &mdash; graduates to a full workshop later</span>
    </div>
    @if (!string.IsNullOrEmpty(_setupMessage))
    {
        <div class="step-result">
            <span class="@(_setupDir is not null ? "ok" : "warn")">@_setupMessage</span>
            @if (_setupDir is not null) { <span class="muted">&rarr; now open a desk in it below</span> }
        </div>
    }
    <div class="step">
        <span class="step-num">2</span>
        <span class="nd-label">open a desk in:</span>
        @foreach (var w in _workshops.Where(w => !w.IsMini))
        {
            <button class="chip @(_deskFolder == w.Dir ? "on" : "")" @onclick="() => PickWorkshop(w.Dir)" title="@w.Dir">@w.Name</button>
        }
        <input class="nd-input wide" @bind="_deskFolder" @bind:event="oninput" @onkeydown="DeskKey" @onfocus="() => _typing = true" @onblur="() => _typing = false" placeholder="a workshop folder, e.g. Ember_workshop" autocomplete="off" spellcheck="false" aria-label="workshop folder to open a desk in" />
        <input class="nd-input" @bind="_deskName" @bind:event="oninput" @onkeydown="DeskKey" @onfocus="() => _typing = true" @onblur="() => _typing = false" placeholder="desk name (optional)" autocomplete="off" spellcheck="false" aria-label="desk name (optional)" />
        @if (_agents.Count > 1)
        {
            <select class="nd-input" @bind="_deskAgent" title="which agent CLI to launch this desk with" aria-label="agent CLI to launch this desk with">
                @foreach (var a in _agents) { <option value="@a.Key">@a.Label</option> }
            </select>
        }
        <button class="btn" @onclick="OpenDesk">open a desk</button>
        @if (!string.IsNullOrEmpty(_deskHint)) { <span class="nd-hint">@_deskHint</span> }
    </div>
</div>
}

<div class="grid">

    @foreach (var wg in _workshopGroups)
    {
        var wgAlerts = AlertsFor(wg);
        var wgStale = StaleFor(wg);
    <section class="panel workshop-card">
        <h2>@wg.Name @if (wg.IsMini) { <span class="mini-badge" title="a local mini-workshop \u2014 no repo">mini &middot; local</span> } <span class="count">@wg.Desks.Count desks</span>
            @if (wg.IsMini)
            {
                <button class="link-btn graduate" @onclick="() => GraduateWorkshop(wg.Dir)" disabled="@_busy" title="create a private repo and make this a full workshop; your work comes along">graduate to full &rarr;</button>
            }
            <button class="icon-btn archive-close" @onclick="() => ArchiveWorkshop(wg.Dir)" aria-label="close this workshop" title="close this workshop \u2014 hides it from the board (kept on disk; reopen from 'closed workshops' below)">&times;</button>
        </h2>
        @if (wgAlerts.Count > 0 || wgStale.Count > 0)
        {
            <div class="ta-strip">
                <span class="ta-title" title="technical assistant">ta</span>
                @if (wgStale.Count > 0)
                {
                    <span class="ta-pill stale" title="@string.Join(", ", wgStale)">@wgStale.Count stale</span>
                }
                @foreach (var alert in wgAlerts.Take(3))
                {
                    <span class="ta-alert @alert.Level" title="@alert.Detail"><span class="ta-alert-text">@alert.Desk: @alert.Summary</span><button class="ta-dismiss" @onclick="() => DismissAlert(alert)" title="dismiss this alert" aria-label="dismiss alert">&times;</button></span>
                }
                @if (wgAlerts.Count > 3)
                {
                    <span class="ta-more">+@(wgAlerts.Count - 3) more</span>
                }
            </div>
        }
        @if (_signals.Count > 0 && wg == _workshopGroups.First())
        {
            <div class="signal-key">
                <span class="key-title">signals:</span>
                <span class="key-item"><span class="signal-type st-execution" aria-hidden="true">&#x25C8;</span> execution</span>
                <span class="key-item"><span class="signal-type st-escalation" aria-hidden="true">&#x26A1;</span> escalation</span>
                <span class="key-item"><span class="signal-type st-partnership" aria-hidden="true">&#x2194;</span> partnership</span>
                <span class="key-sep">|</span>
                <span class="key-item">weakest score (hover for all 4: intent · confidence · accuracy · completeness)</span>
            </div>
        }
        @if (wg.Desks.Count > 0)
        {
        <table>
            <thead><tr><th scope="col">desk</th><th scope="col">modality</th><th scope="col">model</th><th scope="col">output</th>@if (_advanced) { <th scope="col">AIC</th> }<th scope="col">status</th><th scope="col">last</th><th></th></tr></thead>
            <tbody>
                @foreach (var d in wg.Desks)
                {
                    var sig = SignalReader.LatestForDesk(_signals, d.Name);
                    <tr>
                        <td><strong>@d.Name</strong>@if (d.Agent != "copilot") { <span class="agent-tag" title="@($"launched with {d.Agent}")">@d.Agent</span> }<div class="sub">@d.Note</div></td>
                        <td><span class="mod mod-@d.Modality">@d.Modality</span></td>
                        <td class="mono">@d.Model</td>
                        <td class="mono tok" title="@($"{d.TokensOut:N0} output tokens (local; input not tracked per-turn)")">@FmtTok(d.TokensOut)</td>
                        @if (_advanced)
                        {
                            <td class="mono aic" title="cloud usage_cost; live CLI runs ahead of last sync">@d.Aic.ToString("N0")</td>
                        }
                        <td>
                            <span class="badge st-@d.Status.Replace("-", "")">@d.Status</span>
                            @if (d.Sync == "wip")
                            {
                                <span class="sync sync-wip" title="uncommitted changes in this folder">&#9679; wip</span>
                            }
                            else if (d.Sync.StartsWith("unpushed"))
                            {
                                <span class="sync sync-ahead" title="commits not pushed to origin/main">&#8593; @d.Sync.Split(':')[1]</span>
                            }
                            else if (d.Sync.StartsWith("behind"))
                            {
                                <span class="sync sync-behind" title="behind origin/main (as of last fetch)">&#8595; @d.Sync.Split(':')[1]</span>
                            }
                            else if (d.Sync == "synced")
                            {
                                <span class="sync sync-ok" title="clean and synced with origin/main" aria-label="synced">&#10003;</span>
                            }
                        </td>
                        <td class="muted">@Ago(d.LastSeen)</td>
                        <td>
                            @if (d.ConsolePid > 0)
                            {
                                <span class="in-console" title="@($"already open in console (pid {d.ConsolePid})")">&#9679; in console</span>
                            }
                            else if (!string.IsNullOrEmpty(d.SessionId))
                            {
                                <button class="icon-btn" @onclick="() => OpenConsole(d)" aria-label="open this desk in a console" title="open this desk's session in a new terminal">&#8599;</button>
                            }
                            @if (!string.IsNullOrEmpty(d.SessionId))
                            {
                                <button class="icon-btn danger" @onclick="() => CloseDesk(d)" disabled="@_closing.Contains(d.SessionId)"
                                        aria-label="close this desk"
                                        title="@(d.ConsolePid > 0 ? "wind down: the agent journals, then this desk closes" : "close and hide this desk")">
                                    @(_closing.Contains(d.SessionId) ? "\u22EF" : "\u00D7")
                                </button>
                            }
                        </td>
                    </tr>
                    @if (sig is not null)
                    {
                        var (weakLabel, weakScore) = WeakestScore(sig);
                        var alertLevel = sig.SignalType == "escalation" ? "alert-escalation"
                            : weakScore <= 2 ? "alert-warn"
                            : "";
                        <tr class="signal-row @alertLevel">
                            <td colspan="@(_advanced ? 8 : 7)">
                                <div class="signal-strip" title="@SignalTooltip(sig)">
                                    <span class="signal-type st-@sig.SignalType" aria-label="@(sig.SignalType) signal">@SignalIcon(sig.SignalType)</span>
                                    @if (sig.SignalType == "escalation")
                                    {
                                        <span class="signal-escalation">&#9889; @Truncate(sig.EscalationReason ?? "needs help", 80)</span>
                                        @if (!string.IsNullOrEmpty(sig.EscalationBlocked))
                                        {
                                            <span class="signal-blocked">blocked: @Truncate(sig.EscalationBlocked, 50)</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="signal-weak @(weakScore <= 2 ? "score-low" : "")">@weakLabel @weakScore/5</span>
                                        @if (weakScore <= 2 && weakLabel == "intent")
                                        {
                                            <span class="signal-warn">may be off track</span>
                                        }
                                        @if (!string.IsNullOrEmpty(sig.WhatWasHard))
                                        {
                                            <span class="signal-note hard">&#9888; @Truncate(sig.WhatWasHard, 55)</span>
                                        }
                                        else if (!string.IsNullOrEmpty(sig.WhatWorked))
                                        {
                                            <span class="signal-note good">&#10003; @Truncate(sig.WhatWorked, 55)</span>
                                        }
                                    }
                                    <span class="signal-age muted">@Ago(sig.EmittedAt)</span>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        }
        @if (wg.Dormant.Count > 0)
        {
            <div class="closed-section">
                <div class="closed-head">
                    <span class="dormant-label"><span aria-hidden="true">&#9711;</span> dormant</span>
                    <span class="closed-count">@wg.Dormant.Count</span>
                </div>
                <div class="closed-strip">
                    @foreach (var d in wg.Dormant)
                    {
                        <span class="dormant-chip" title="@d.Path (@d.Location/)">@d.Name <button class="icon-btn" @onclick="() => StartDormantDesk(d)" aria-label="start a desk here" title="start a desk in this folder">&#9654;</button></span>
                    }
                </div>
            </div>
        }
        @if (wg.Desks.Count == 0 && wg.Dormant.Count == 0)
        {
            <div class="empty">no desks yet &mdash; <button class="link-btn" @onclick="() => OpenDeskHere(wg.Dir)">open a desk here</button></div>
        }
    </section>
    }

    @* Sessions not part of any workshop — the "not in a workshop yet" group (JM issue #1) *@
    @{ var grouped = _workshopGroups.SelectMany(g => g.Desks).Select(d => d.SessionId).ToHashSet(); }
    @{ var orphans = _desks.Where(d => !grouped.Contains(d.SessionId)).ToList(); }
    @if (orphans.Count > 0)
    {
    <div class="setup-bar @(_orphansOpen ? "open" : "collapsed")" role="button" tabindex="0" aria-expanded="@(_orphansOpen ? "true" : "false")" aria-controls="orphans-body"
         @onclick="ToggleOrphans" @onkeydown="OrphansKey" title="@(_orphansOpen ? "hide these sessions" : "show these sessions")">
        <span class="setup-caret" aria-hidden="true">@(_orphansOpen ? "\u25BE" : "\u25B8")</span>
        <span class="setup-bar-label">@orphans.Count not in a workshop yet</span>
        <span class="muted setup-bar-sub">loose Copilot sessions &mdash; create a workshop above to group and coordinate them</span>
    </div>
    @if (_orphansOpen)
    {
    <section class="panel workshop-card no-workshop" id="orphans-body">
        <table>
            <thead><tr><th scope="col">desk</th><th scope="col">modality</th><th scope="col">model</th><th scope="col">output</th>@if (_advanced) { <th scope="col">AIC</th> }<th scope="col">status</th><th scope="col">last</th><th></th></tr></thead>
            <tbody>
                @foreach (var d in orphans)
                {
                    <tr>
                        <td><strong>@d.Name</strong>@if (d.Agent != "copilot") { <span class="agent-tag" title="@($"launched with {d.Agent}")">@d.Agent</span> }<div class="sub">@d.Note</div></td>
                        <td><span class="mod mod-@d.Modality">@d.Modality</span></td>
                        <td class="mono">@d.Model</td>
                        <td class="mono tok" title="@($"{d.TokensOut:N0} output tokens (local; input not tracked per-turn)")">@FmtTok(d.TokensOut)</td>
                        @if (_advanced)
                        {
                            <td class="mono aic">@d.Aic.ToString("N0")</td>
                        }
                        <td><span class="badge st-@d.Status.Replace("-", "")">@d.Status</span></td>
                        <td class="muted">@Ago(d.LastSeen)</td>
                        <td>
                            @if (d.ConsolePid > 0)
                            {
                                <span class="in-console">&#9679; in console</span>
                            }
                            else if (!string.IsNullOrEmpty(d.SessionId))
                            {
                                <button class="icon-btn" @onclick="() => OpenConsole(d)" aria-label="open this desk in a console" title="open this desk's session in a new terminal">&#8599;</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
    }
    }

    @if (_workshopGroups.Count == 0 && _desks.Count == 0)
    {
    <section class="panel">
        <div class="empty">nothing here yet &mdash; create a workshop above, or a local mini-workshop (no repo needed), then open a desk in it. your open Copilot sessions show up here too.</div>
    </section>
    }

    @if (_closed.Count > 0)
    {
    <section class="panel">
        <div class="closed-section">
            <div class="closed-head">
                <span class="closed-label"><span aria-hidden="true">&#9724;</span> closed desks</span>
                <span class="closed-count">@_closed.Count</span>
            </div>
            <div class="closed-strip">
                @foreach (var c in _closed)
                {
                    <span class="closed-chip">@c.Name <button class="icon-btn" @onclick="() => ReopenDesk(c.SessionId)" aria-label="reopen this desk" title="bring this desk back to the board">&#8635;</button></span>
                }
            </div>
        </div>
    </section>
    }

    @if (_archivedWorkshops.Count > 0)
    {
    <div class="setup-bar @(_archivedOpen ? "open" : "collapsed")" role="button" tabindex="0" aria-expanded="@(_archivedOpen ? "true" : "false")" aria-controls="closed-workshops-body"
         @onclick="ToggleArchived" @onkeydown="ArchivedKey" title="@(_archivedOpen ? "hide" : "show closed workshops")">
        <span class="setup-caret" aria-hidden="true">@(_archivedOpen ? "\u25BE" : "\u25B8")</span>
        <span class="setup-bar-label">@_archivedWorkshops.Count closed workshop@(_archivedWorkshops.Count == 1 ? "" : "s")</span>
        <span class="muted setup-bar-sub">hidden from the board, restore any time</span>
    </div>
    @if (_archivedOpen)
    {
    <section class="panel" id="closed-workshops-body">
        <div class="closed-strip">
            @foreach (var w in _archivedWorkshops)
            {
                <span class="closed-chip">@w.Name@if (w.IsMini) { <span class="mini-tag"> mini</span> } <button class="icon-btn" @onclick="() => RestoreWorkshop(w.Dir)" aria-label="restore this workshop" title="bring this workshop back to the board \u2014 whole, with all its work">&#8635;</button></span>
            }
        </div>
    </section>
    }
    }

    @if (_advanced)
    {
    <section class="panel">
        <h2>bench <span class="count">@_artifact.Ref</span></h2>
        <ol class="bench">
            @foreach (var t in _bench)
            {
                <li class="@(t.Seq == _bench.Count ? "latest" : "")">
                    <span class="seq">#@t.Seq</span>
                    <span class="kind k-@t.Kind">@t.Kind</span>
                    <span class="body">@t.Body</span>
                    <span class="meta">
                        @if (t.Confidence is double cf) { <span class="conf">@cf.ToString("0.00")</span> }
                        <span class="sig">&#9670; @t.SignedBy</span>
                        <span class="muted">@Ago(t.Ts)</span>
                    </span>
                </li>
            }
        </ol>
    </section>
    }

    @if (_advanced)
    {
    <section class="panel">
        <h2>hands-up <span class="count">@_handsup.Count(h => h.Status == "open")</span></h2>
        @if (_handsup.Count == 0)
        {
            <div class="empty">nothing for the operator. the workshop is settling its own disagreements.</div>
        }
        @foreach (var h in _handsup)
        {
            <div class="handsup">
                <div class="q">@h.Question</div>
                <div class="meta"><span class="sig">&#9670; @h.RaisedBy</span> <span class="badge st-open">@h.Status</span> <span class="muted">@Ago(h.Ts)</span> <button class="link-btn" @onclick="() => Resolve(h)">resolve</button></div>
            </div>
        }
    </section>
    }

    @if (_advanced)
    {
    <section class="panel">
        <h2>handoffs <span class="count">@_handoffs.Count</span></h2>
        @foreach (var h in _handoffs)
        {
            <div class="handoff">
                <div class="task"><span class="badge ho-@h.State">@h.State</span> @h.Task</div>
                <div class="line"><span class="lbl">from</span> @h.SourceDesk @if (h.ClaimedBy is not null) { <span class="arrow">&rarr;</span> <strong>@h.ClaimedBy</strong> }</div>
                <div class="line"><span class="lbl">scope</span> <span class="scope">@h.Scope</span></div>
                <div class="line"><span class="lbl">sources</span> <span class="muted">@h.Sources</span></div>
                @if (h.Receipt is not null)
                {
                    <div class="line receipt"><span class="lbl">receipt</span> @h.Receipt</div>
                }
            </div>
        }
    </section>
    }

</div>

<footer class="room-foot">
    reading <span class="mono">~/.copilot/session-state</span> live &middot; cost from the cloud usage store &middot; the workshop
</footer>

@code {
    private Artifact _artifact = new(0, "-", "");
    private List<Desk> _desks = new();
    private List<BenchTurn> _bench = new();
    private List<HandsUp> _handsup = new();
    private List<Handoff> _handoffs = new();
    private Health _health = new(0, 0, 0, 0, 0, null, null);
    private Pulse _pulse = new("warming up", "", new());
    private DateTime _now = DateTime.UtcNow;
    private string _usageAsOf = "";
    private string _deskFolder = "";
    private string _deskName = "";
    private string _deskAgent = "copilot";
    private List<AgentCli> _agents = new() { AgentClis.Copilot };
    private string _deskHint = "";
    private readonly HashSet<string> _closing = new();
    private List<WorkshopLauncher.WorkshopInfo> _workshops = new();
    private List<WorkshopLauncher.WorkshopInfo> _archivedWorkshops = new();
    private List<ClosedDesk> _closed = new();
    private List<WorkshopLauncher.DeskFolder> _dormant = new();
    private List<AgentSignal> _signals = new();
    private List<TaAlert> _taAlerts = new();
    private List<string> _staleDesks = new();
    private List<WorkshopGroup> _workshopGroups = new();
    private bool _advanced;   // false = "keep it simple" default; true = "show me everything"
    private bool _setupOpen;  // the create-workshop/open-desk section; collapsed by default once a workshop exists (clean first-run)
    private bool _orphansOpen;  // the "not in a workshop yet" sessions; collapsed by default to keep the board clean
    private bool _archivedOpen; // the closed (archived) workshops strip; collapsed by default so it stays out of the way
    private bool _isLight;    // reflects the client theme (synced after first render)
    private string _newWorkshopName = "";
    private string _newMiniName = "";
    private string _workshopOwner = "";
    private string _setupMessage = "";
    private string? _setupDir;
    private List<GhLogin> _ghLogins = new();
    private bool _busy;
    private bool _typing;
    private Timer? _tick;

    protected override void OnInitialized()
    {
        Load();
        // Clean first-run: the setup is open when there's nothing yet, and
        // collapsed once you already have a workshop (it's just noise then).
        _setupOpen = _workshops.Count == 0;
        _ghLogins = GhAuth.DiscoverLogins().ToList();
        _workshopOwner = _ghLogins.FirstOrDefault(l => l.IsActive)?.Login ?? _ghLogins.FirstOrDefault()?.Login ?? "";
        _agents = AgentClis.Available();
        _tick = new Timer(_ => InvokeAsync(() =>
        {
            if (_typing) return;
            _now = DateTime.UtcNow;
            Load();
            StateHasChanged();
        }), null, TimeSpan.FromSeconds(3), TimeSpan.FromSeconds(3));
    }

    // The theme is applied client-side (before paint) from localStorage; after
    // the first render we read it back so the toggle's label matches.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var t = await JS.InvokeAsync<string>("workshopTheme.get");
            var light = string.Equals(t, "light", StringComparison.OrdinalIgnoreCase);
            if (light != _isLight) { _isLight = light; StateHasChanged(); }
        }
        catch { /* JS not ready — the label just defaults to dark */ }
    }

    private async Task ToggleTheme()
    {
        try
        {
            var t = await JS.InvokeAsync<string>("workshopTheme.toggle");
            _isLight = string.Equals(t, "light", StringComparison.OrdinalIgnoreCase);
        }
        catch { /* JS unavailable — no-op */ }
    }

    private void Load()
    {
        var s = Reader.GetSnapshot();
        _artifact = s.Artifact; _desks = s.Desks; _bench = s.Bench;
        _handsup = s.HandsUp; _handoffs = s.Handoffs; _health = s.Health; _pulse = s.Pulse;
        _usageAsOf = s.UsageAsOf;
        _now = DateTime.UtcNow;
        var allWorkshops = WorkshopLauncher.ListWorkshops(Config.WorkshopsBaseDir);
        var archived = Archive.Archived();
        _workshops = allWorkshops.Where(w => !archived.Contains(w.Dir)).ToList();
        _archivedWorkshops = allWorkshops.Where(w => archived.Contains(w.Dir)).ToList();
        _closed = Reader.ClosedDesks();

        // Dormant = desk folders on disk that have no active session on the board.
        var activeNames = new HashSet<string>(_desks.Select(d => d.Name), StringComparer.OrdinalIgnoreCase);
        _dormant = _workshops
            .SelectMany(w => WorkshopLauncher.ListDeskFolders(w.Dir))
            .Where(df => !activeNames.Contains(df.Name))
            .ToList();

        // Group desks by workshop — match desk Cwd to workshop Dir
        _workshopGroups = _workshops.Select(w =>
        {
            var wDesks = _desks.Where(d =>
                !string.IsNullOrEmpty(d.Cwd) &&
                d.Cwd.StartsWith(w.Dir, StringComparison.OrdinalIgnoreCase)).ToList();
            var wDormant = WorkshopLauncher.ListDeskFolders(w.Dir)
                .Where(df => !activeNames.Contains(df.Name)).ToList();
            return new WorkshopGroup(w.Name, w.Dir, w.IsMini, wDesks, wDormant);
        }).ToList();   // every workshop gets a card, even before it has a desk — so a freshly-created one shows up immediately

        // Signals = latest agent signal per desk (from .signals/ folders)
        _signals = SignalReader.ReadLatestSignals(_workshops.Select(w => w.Dir));

        // TA layer: detect stale desks + surface actionable alerts from signals.
        // Alerts the operator dismisses (× on the pill) stay gone until that desk
        // emits a newer signal.
        var staleThreshold = TimeSpan.FromHours(4);
        _staleDesks = _desks
            .Where(d => (DateTime.UtcNow - d.LastSeen) > staleThreshold && d.ConsolePid == 0)
            .Select(d => d.Name)
            .ToList();

        var dismissed = Reader.DismissedAlerts();
        _taAlerts = new();
        foreach (var sig in _signals)
        {
            TaAlert? alert = null;
            if (sig.SignalType == "escalation")
                alert = new TaAlert(sig.DeskName, "escalation", "⚡ " + (sig.EscalationReason ?? "needs help"), sig.EscalationBlocked ?? "", sig.EmittedAt);
            else if (sig.Intent > 0 && sig.Intent <= 2)
                alert = new TaAlert(sig.DeskName, "warn", $"intent {sig.Intent}/5 — may be off track", sig.WhatWasHard ?? "", sig.EmittedAt);
            else
            {
                var (label, score) = WeakestScore(sig);
                if (score <= 2)
                    alert = new TaAlert(sig.DeskName, "warn", $"{label} {score}/5", sig.WhatWasHard ?? "", sig.EmittedAt);
            }
            if (alert is not null && !dismissed.Contains(SessionStoreReader.AlertKey(alert.Desk, alert.Summary, alert.EmittedAt)))
                _taAlerts.Add(alert);
        }
    }

    private void OpenConsole(Desk d) => ConsoleLauncher.Open(d.SessionId, d.Cwd, d.Agent, Config.SettingsFor(d.Agent));

    // Close a desk from the board. If a live agent still holds it (a console pid),
    // wind it down gracefully — end the terminal, let the agent journal — then
    // hide it. An idle desk is just hidden.
    private async Task CloseDesk(Desk d)
    {
        if (string.IsNullOrEmpty(d.SessionId) || _closing.Contains(d.SessionId)) return;
        _closing.Add(d.SessionId);
        StateHasChanged();
        if (d.ConsolePid > 0)
            await Task.Run(() => DeskCloser.Close(d.SessionId, d.Cwd, d.ConsolePid, d.Name));
        Reader.Close(d.SessionId);
        _closing.Remove(d.SessionId);
        Load();
        StateHasChanged();
    }

    // Bring a closed desk back to the board.
    private void ReopenDesk(string sessionId)
    {
        Reader.Reopen(sessionId);
        Load();
        StateHasChanged();
    }

    // Start a dormant desk — a folder that exists on disk but has no active session.
    private void StartDormantDesk(WorkshopLauncher.DeskFolder df)
    {
        var workshopDir = System.IO.Path.GetDirectoryName(System.IO.Path.GetDirectoryName(df.Path))!;
        var orient = WorkshopLauncher.DeskOrientPrompt(df);
        ConsoleLauncher.NewDesk(workshopDir, df.Name, orient, _deskAgent, Config.SettingsFor(_deskAgent));
        DeskAgents.RecordLaunch(workshopDir, _deskAgent, df.Name);   // remember which CLI launched it (issue #2)
    }

    private void Resolve(HandsUp h)
    {
        Reader.Resolve(h.RaisedBy, h.Question);
        Load();
        StateHasChanged();
    }

    // Dismiss a TA alert the operator has handled. It stays gone until that desk
    // emits a newer signal.
    private void DismissAlert(TaAlert a)
    {
        Reader.DismissAlert(SessionStoreReader.AlertKey(a.Desk, a.Summary, a.EmittedAt));
        Load();
        StateHasChanged();
    }

    // Open a desk into a chosen workshop. The desk's working directory is the
    // workshop root (so every desk shares that one bench); the name is only the
    // session label. Nothing is combined from a bare name, so a desk can't land
    // anywhere but inside a real workshop.
    // A workshop chip was clicked: fill the folder field with it (the operator
    // can still add a desk name before opening).
    private void PickWorkshop(string dir) { _deskFolder = dir; _deskHint = ""; }

    // From a workshop card: open a desk right here (default name, current agent),
    // then refresh so the new desk shows on the card immediately.
    private void OpenDeskHere(string dir)
    {
        _deskFolder = dir;
        OpenDeskIn(dir, "");
        Load();
        StateHasChanged();
    }

    // Open a desk in a workshop folder that already exists. Bare names resolve
    // under the workshops base dir; a full path is used as-is. The folder must
    // exist — we never create one here, so a typo can't spawn a stray folder.
    private void OpenDesk()
    {
        var input = _deskFolder.Trim();
        if (input.Length == 0) { _deskHint = "type a workshop folder first"; return; }
        var dir = (input.Contains('\\') || input.Contains('/') || input.Contains(':'))
            ? input
            : System.IO.Path.Combine(Config.WorkshopsBaseDir, input);
        if (!System.IO.Directory.Exists(dir)) { _deskHint = $"no folder at {dir} — create a workshop first"; return; }
        OpenDeskIn(dir, _deskName.Trim());
        _deskName = "";
    }

    // Launch a desk in an existing workshop folder: scaffold its space, open the
    // chosen agent CLI there, and remember which agent launched it.
    private void OpenDeskIn(string dir, string name)
    {
        _deskHint = "";
        name = WorkshopLauncher.SafeDeskName(name);              // single safe segment; blocks path traversal / shell metachars in the desk name
        WorkshopLauncher.PrepareDesk(dir, name);                 // give the desk its own space + journal + brief
        var orient = $"read ./desks/{name}/START-HERE.md, then get going";
        ConsoleLauncher.NewDesk(dir, name, orient, _deskAgent, Config.SettingsFor(_deskAgent));  // open at the workshop root, auto-oriented
        DeskAgents.RecordLaunch(dir, _deskAgent, name);          // remember which CLI launched it (issue #2)
    }

    private void ToggleSetup() => _setupOpen = !_setupOpen;

    private void SetupKey(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or " " or "Spacebar") _setupOpen = !_setupOpen;
    }

    private void ToggleOrphans() => _orphansOpen = !_orphansOpen;

    private void OrphansKey(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or " " or "Spacebar") _orphansOpen = !_orphansOpen;
    }

    private void ToggleArchived() => _archivedOpen = !_archivedOpen;

    private void ArchivedKey(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or " " or "Spacebar") _archivedOpen = !_archivedOpen;
    }

    private void DeskKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") OpenDesk();
    }

    private async Task StartWorkshop()
    {
        var name = _newWorkshopName.Trim();
        if (name.Length == 0) { _setupMessage = "name the workshop first"; _setupDir = null; return; }
        if (string.IsNullOrWhiteSpace(_workshopOwner)) { _setupMessage = "no gh account found — run gh auth login"; _setupDir = null; return; }
        _busy = true; _setupMessage = "creating the private repo..."; _setupDir = null; StateHasChanged();
        var active = _ghLogins.FirstOrDefault(l => l.IsActive)?.Login;
        var result = await Task.Run(() => WorkshopLauncher.NewWorkshop(_workshopOwner, name, Config.WorkshopsBaseDir, active));
        _busy = false;
        _setupMessage = result.Message;
        _setupDir = result.Ok ? result.Dir : null;   // ready; the operator opens a desk deliberately
        if (result.Ok)
        {
            _newWorkshopName = "";
            if (result.Dir is not null) _deskFolder = result.Dir;   // prefill step 2 with the new workshop
        }
        StateHasChanged();
    }

    private async Task StartMiniWorkshop()
    {
        var name = _newMiniName.Trim();
        if (name.Length == 0) { _setupMessage = "name the mini-workshop first"; _setupDir = null; return; }
        _busy = true; _setupMessage = "creating a local mini-workshop..."; _setupDir = null; StateHasChanged();
        var result = await Task.Run(() => WorkshopLauncher.NewMiniWorkshop(name, Config.WorkshopsBaseDir));
        _busy = false;
        _setupMessage = result.Message;
        _setupDir = result.Ok ? result.Dir : null;
        if (result.Ok)
        {
            _newMiniName = "";
            if (result.Dir is not null) _deskFolder = result.Dir;   // prefill step 2 with the new mini-workshop
        }
        StateHasChanged();
    }

    private async Task GraduateWorkshop(string dir)
    {
        if (string.IsNullOrWhiteSpace(_workshopOwner)) { _setupMessage = "pick an owner account (in step 1) to graduate into"; _setupDir = null; StateHasChanged(); return; }
        _busy = true; _setupMessage = $"graduating {System.IO.Path.GetFileName(dir)} — creating the private repo..."; _setupDir = null; StateHasChanged();
        var active = _ghLogins.FirstOrDefault(l => l.IsActive)?.Login;
        var result = await Task.Run(() => WorkshopLauncher.GraduateWorkshop(dir, _workshopOwner, active));
        _busy = false;
        _setupMessage = result.Message;
        _setupDir = result.Ok ? result.Dir : null;
        Load();   // refresh: the card drops its 'mini' badge once it's a full workshop
        StateHasChanged();
    }

    // Archive a workshop: hide it from the board. The folder — bench, desks, and
    // all its work — stays whole on disk, so it restores intact.
    private void ArchiveWorkshop(string dir)
    {
        Archive.Archive(dir);
        Load();
        StateHasChanged();
    }

    private void RestoreWorkshop(string dir)
    {
        Archive.Restore(dir);
        Load();
        StateHasChanged();
    }

    private static string Conf(double? v) => v is double d ? d.ToString("0.00") : "-";

    private static string FmtTok(long n)
    {
        if (n <= 0) return "-";
        if (n >= 1_000_000) return (n / 1_000_000.0).ToString("0.0") + "M";
        if (n >= 1_000) return (n / 1_000.0).ToString("0.0") + "K";
        return n.ToString();
    }

    private string PulseClass() => _pulse.Temperature switch
    {
        "above the line" => "above",
        "below the line" => "below",
        _ => "warm"
    };

    private string Arrow() => _pulse.Temperature switch
    {
        "above the line" => "\u25B2",
        "below the line" => "\u25BC",
        _ => "\u25C6"
    };

    private string Spread()
    {
        if (_health.ConfMin is double lo && _health.ConfMax is double hi) return (hi - lo).ToString("0.00");
        return "-";
    }

    private string Ago(DateTime tsUtc)
    {
        var s = (_now - tsUtc).TotalSeconds;
        if (s < 0) s = 0;
        if (s < 60) return $"{(int)s}s ago";
        if (s < 3600) return $"{(int)(s / 60)}m ago";
        return $"{(int)(s / 3600)}h ago";
    }

    private static string SignalIcon(string type) => type switch
    {
        "escalation" => "\u26A1",   // lightning bolt
        "partnership" => "\u2194",  // left-right arrow
        "outcome" => "\u2713",      // checkmark
        _ => "\u25C8"               // diamond (execution)
    };

    private static (string label, int score) WeakestScore(AgentSignal sig)
    {
        // Return the lowest non-zero score (where the operator should look).
        // Intent leads in ties because a misunderstood ask invalidates everything else.
        var scores = new (string label, int score)[]
        {
            ("intent", sig.Intent),
            ("confidence", sig.Confidence),
            ("accuracy", sig.Accuracy),
            ("completeness", sig.Completeness)
        };
        var lowest = scores.Where(s => s.score > 0).OrderBy(s => s.score).ThenBy(s => s.label == "intent" ? 0 : 1).FirstOrDefault();
        return lowest.score > 0 ? lowest : ("confidence", 0);
    }

    private static string SignalTooltip(AgentSignal sig) =>
        $"intent {sig.Intent}/5 · confidence {sig.Confidence}/5 · accuracy {sig.Accuracy}/5 · completeness {sig.Completeness}/5" +
        (string.IsNullOrEmpty(sig.WhatWorked) ? "" : $"\n✓ {sig.WhatWorked}") +
        (string.IsNullOrEmpty(sig.WhatWasHard) ? "" : $"\n⚠ {sig.WhatWasHard}") +
        (string.IsNullOrEmpty(sig.SkillGap) ? "" : $"\n◇ skill gap: {sig.SkillGap}");

    private static string ScoreDots(int score) => score switch
    {
        >= 5 => "\u25CF\u25CF\u25CF\u25CF\u25CF",
        4 => "\u25CF\u25CF\u25CF\u25CF\u25CB",
        3 => "\u25CF\u25CF\u25CF\u25CB\u25CB",
        2 => "\u25CF\u25CF\u25CB\u25CB\u25CB",
        1 => "\u25CF\u25CB\u25CB\u25CB\u25CB",
        _ => "\u25CB\u25CB\u25CB\u25CB\u25CB"
    };

    private static string Truncate(string s, int max) =>
        s.Length <= max ? s : s[..max] + "\u2026";

    // The TA (coordination) alerts and stale desks that belong to one workshop,
    // matched by desk name — so each workshop card shows its own, instead of one
    // global strip floating at the top of the board. Signals are keyed by desk
    // *folder* name, so we match against both live desks and dormant desk
    // folders (a desk can raise a signal and then go dormant).
    private static HashSet<string> DeskNamesIn(WorkshopGroup wg)
    {
        var names = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var d in wg.Desks) names.Add(d.Name);
        foreach (var df in wg.Dormant) names.Add(df.Name);
        return names;
    }

    private List<TaAlert> AlertsFor(WorkshopGroup wg)
    {
        var names = DeskNamesIn(wg);
        return _taAlerts.Where(a => names.Contains(a.Desk)).ToList();
    }

    private List<string> StaleFor(WorkshopGroup wg)
    {
        var names = DeskNamesIn(wg);
        return _staleDesks.Where(names.Contains).ToList();
    }

    private record TaAlert(string Desk, string Level, string Summary, string Detail, DateTime EmittedAt);

    private record WorkshopGroup(string Name, string Dir, bool IsMini, List<Desk> Desks, List<WorkshopLauncher.DeskFolder> Dormant);

    public void Dispose() => _tick?.Dispose();
}
